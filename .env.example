# FODMAP Detector — Environment Variables
# Copy this file to .env and fill in your values.
# These override any settings in service.yaml.

# Required for chat endpoint
GOOGLE_API_KEY=

# JWT signing secret (auto-generates an insecure default if unset)
JWT_SECRET=

# Optional: Bearer token for legacy /chat endpoint (omit to use JWT-only auth)
CHAT_API_KEY=

# Optional: Weaviate Cloud credentials
# WEAVIATE_API_KEY=
# WEAVIATE_SCHEME=https

# Optional: Pinecone Cloud credentials
# PINECONE_API_KEY=
# PINECONE_INDEX_HOST=

# Optional: PostgreSQL connection string
# POSTGRES_DSN=
